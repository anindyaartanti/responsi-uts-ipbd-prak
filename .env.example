# ============================================================
# Wired Pipeline — Environment Variables
# Salin file ini menjadi .env dan sesuaikan nilainya
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_ROOT_USER=postgres
POSTGRES_ROOT_PASSWORD=postgres_root

# ── Wired Pipeline Database ─────────────────────────────────
WIRED_DB_NAME=wired_pipeline
WIRED_DB_USER=wired_user
WIRED_DB_PASSWORD=wired_pass      # Ganti di production!

# ── Airflow Database ─────────────────────────────────────────
AIRFLOW_DB_NAME=airflow_db
AIRFLOW_DB_USER=airflow_user
AIRFLOW_DB_PASSWORD=airflow_pass  # Ganti di production!

# ── Airflow ─────────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin      # Ganti di production!
AIRFLOW_SECRET_KEY=change-me-in-production

# ── FastAPI ─────────────────────────────────────────────────
API_PORT=8000
DATA_DIR=./data
